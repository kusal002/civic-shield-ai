# Added in Step 6. Never expose this value in browser code.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Gmail OAuth for citizen-confirmed sending (Step 7)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback

# Optional: one CivicShield owner Gmail refresh token for direct site-wide sending.
# Never expose this in browser code or Git.
GMAIL_REFRESH_TOKEN=

# Hackathon mode: all citizen-confirmed report emails are delivered here in
# the background while the UI shows a dynamic nearby department suggestion.
HACKATHON_INBOX_EMAIL=kushalkg0000@gmail.com

# Civic Sense social-awareness submissions.
# User submissions are queued for moderator review and emailed here.
CIVIC_SENSE_MODERATOR_EMAIL=kushalkg0000@gmail.com
CIVIC_SENSE_INSTAGRAM_HANDLE=civicshieldai
CIVIC_SENSE_MEDIA_BUCKET=civic-sense-media
# Used for text-only or voice-only Instagram posts. Must be publicly reachable.
CIVIC_SENSE_DEFAULT_IMAGE_URL=

# Public deployed site URL. Used as a fallback default-image URL:
# https://YOUR_DOMAIN/icons/civicshield-logo.png
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Official Instagram Graph API publishing credentials.
# The Instagram account must be eligible for API publishing.
INSTAGRAM_API_VERSION=v23.0
INSTAGRAM_IG_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# Supabase persistent report tracking (Step 8)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=you
# Server-only. Never prefix with NEXT_PUBLIC_ and never commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# Optional but recommended for emergency nearby help.
# Enables live nearby police, hospitals, ambulance services, fire stations,
# phone numbers, and safer public places through Google Places API.
GOOGLE_MAPS_API_KEY=

# Moderator-only status updates (Step 8 hardening). Use long random values.
MODERATOR_ACCESS_KEY=
MODERATOR_SESSION_SECRET=
